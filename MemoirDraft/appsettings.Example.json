{
  "ConnectionStrings": {
    "Default": "Host=YOUR_HOST;Port=YOUR_PORT;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Debug",
        "System": "Debug"
      }
    }
  },
  "Settings": {
    "AppMode" : "Auth"
  },
  "Storage": {
    "Mode": "DatabaseAndFile",
    "NotesPath": "Notes"
  }
}