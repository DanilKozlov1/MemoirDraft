<Application x:Class="MemoirDraft.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MemoirDraft.Views"
             xmlns:viewModels="clr-namespace:MemoirDraft.ViewModels"
             xmlns:converters="clr-namespace:MemoirDraft.Utils">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Конвертеры -->
            <converters:NullToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

            <!-- DataTemplate для страницы входа -->
            <DataTemplate DataType="{x:Type viewModels:LoginPageModel}">
                <views:LoginPage />
            </DataTemplate>

            <!-- DataTemplate для страницы регистрации -->
            <DataTemplate DataType="{x:Type viewModels:RegisterPageModel}">
                <views:RegisterPage />
            </DataTemplate>

            <!-- DataTemplate для простой заметки -->
            <DataTemplate DataType="{x:Type viewModels:SimpleNotePageModel}">
                <views:SimpleNotePage />
            </DataTemplate>

            <!-- DataTemplate для todo заметки -->
            <DataTemplate DataType="{x:Type viewModels:TodoNotePageModel}">
                <views:TodoNotePage />
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>