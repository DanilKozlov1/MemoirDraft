<Window x:Class="MemoirDraft.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MemoirDraft.Views"
        Title="MemoirDraft" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border x:Name="HeaderBorder" Grid.Row="0" 
                Background="{StaticResource AccentRedBrush}" 
                BorderBrush="{StaticResource GoldBrush}" 
                BorderThickness="0,0,0,2"
                MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип и название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/Images/logo.png" Width="32" Height="32" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MEMOIR DRAFT" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontWeight="Bold" FontSize="18"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Кнопка закрытия (команда из ViewModel) -->
                <Button Grid.Column="2" 
                        Content="✕" 
                        Width="30" Height="30" 
                        Background="#660000" 
                        BorderBrush="{StaticResource GoldBrush}" 
                        BorderThickness="1"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="16" 
                        Cursor="Hand"
                        Command="{Binding CloseCommand}"
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource GoldBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <TextBlock Text="МЕНЮ" 
                               Foreground="{StaticResource GoldBrush}" 
                               FontWeight="Bold" FontSize="16"
                               Margin="0,0,0,20"/>
                    <Button Content="➕ Создать заметку" 
                            Command="{Binding CreateNoteCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,15"/>
                    <!-- Здесь позже появятся другие кнопки -->
                </StackPanel>
            </Border>

            <!-- Правая часть: фильтры + список -->
            <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель фильтров -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <ItemsControl ItemsSource="{Binding Filters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}" 
                        Command="{Binding DataContext.FilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource FilterButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Список заметок -->
                    <ListBox x:Name="NotesListBox" 
                             Grid.Row="1"
                             ItemsSource="{Binding Notes}"
                             Background="Transparent" 
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!-- Карточка заметки -->
                                <Border Background="{StaticResource PanelBrush}" 
                                        CornerRadius="6" 
                                        Margin="0,0,0,10" 
                                        Padding="12,10"
                                        BorderBrush="{StaticResource GoldBrush}" 
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Название -->
                                        <TextBlock Grid.Row="0" 
                                                   Text="{Binding Title}" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="16" 
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,4"/>

                                        <!-- Тип -->
                                        <TextBlock Grid.Row="1" 
                                                   Text="{Binding NoteTypeName}" 
                                                   Foreground="{StaticResource SilverBrush}" 
                                                   FontSize="12"
                                                   Margin="0,0,0,8"/>

                                        <!-- Кнопки -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Stretch">
                                            <Button Content="Открыть" 
                                                    Style="{StaticResource SecondaryButton}"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    Height="38"
                                                    Margin="0,0,10,0"
                                                    Command="{Binding DataContext.OpenNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑️" 
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="50"
                                                    Height="38"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>