<UserControl x:Class="MemoirDraft.Views.RegisterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Width="350">
            <TextBlock Text="РЕГИСТРАЦИЯ" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource GoldBrush}" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <Label Content="Имя пользователя" 
                   Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBox x:Name="RegisterUsernameBox" 
                     Text="{Binding Username}"
                     Margin="0,0,0,15"/>

            <Label Content="Пароль" 
                   Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBox x:Name="RegisterPasswordBox" 
                     Text="{Binding Password}"
                     Margin="0,0,0,15"/>

            <TextBlock Text="{Binding ErrorMessage}" 
                   Foreground="Red" 
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibility}}"/>

            <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                    x:Name="RegisterButton"
                    Command="{Binding RegistrationCommand}"
                    Width="185" Height="40"
                    HorizontalAlignment="Center" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>