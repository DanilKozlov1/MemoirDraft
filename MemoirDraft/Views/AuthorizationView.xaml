<Window x:Class="MemoirDraft.Views.AuthorizationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MemoirDraft" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border x:Name="HeaderBorder" Grid.Row="0" 
                Background="{StaticResource AccentRedBrush}" 
                BorderBrush="{StaticResource GoldBrush}" 
                BorderThickness="0,0,0,2"
                MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="MEMOIR DRAFT" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontWeight="Bold" FontSize="18"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Кнопки переключения -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="LoginTabButton" 
                            Content="ВХОД" 
                            Style="{StaticResource TabButton}"
                            Command="{Binding SwitchToLoginCommand}"/>
                    <Button x:Name="RegisterTabButton" 
                            Content="РЕГИСТРАЦИЯ" 
                            Style="{StaticResource TabButton}"
                            Command="{Binding SwitchToRegisterCommand}"/>
                </StackPanel>

                <!-- Кнопка закрытия -->
                <Button Grid.Column="2" 
                        Content="✕" 
                        Width="30" Height="30" 
                        Margin="0,0,10,0" 
                        Background="#660000" 
                        BorderBrush="{StaticResource GoldBrush}" 
                        BorderThickness="1"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="16" 
                        Cursor="Hand"
                        Command="{Binding CloseCommand}"
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Область страниц -->
        <ContentControl  x:Name="ContentFrame" Grid.Row="1" 
               Content="{Binding CurrentPage}"
               Background="{StaticResource BackgroundBrush}"/>
    </Grid>
</Window>