<Page x:Class="MemoirDraft.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="RegisterPage"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Width="350">
            <TextBlock Text="РЕГИСТРАЦИЯ" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource GoldBrush}" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <Label Content="Имя пользователя" 
                   Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBox x:Name="RegisterUsernameBox" Margin="0,0,0,15"/>

            <Label Content="Пароль" 
                   Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBox x:Name="RegisterPasswordBox" Margin="0,0,0,15"/>

            <Label Content="Подтверждение пароля" 
                   Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBox x:Name="RegisterConfirmPasswordBox" Margin="0,0,0,30"/>

            <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                    x:Name="RegisterButton"
                    Width="185" Height="40"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>