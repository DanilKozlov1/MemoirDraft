<UserControl x:Class="MemoirDraft.Views.TodoNotePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Разделитель -->
        <Rectangle Grid.Row="0" Height="1" Fill="{StaticResource GoldBrush}" Margin="0,0,0,20"/>

        <!-- Название -->
        <Label Grid.Row="1" Content="НАЗВАНИЕ" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" Text="{Binding Title}" Margin="0,0,0,20" Padding="10" FontSize="14"/>

        <!-- Добавление задачи -->
        <Label Grid.Row="3" Content="ДОБАВИТЬ ЗАДАЧУ" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox Text="{Binding NewTodoText}" Width="250" Padding="10" FontSize="14" Margin="0,0,10,0"/>
            <Button Content="ДОБАВИТЬ" Command="{Binding AddTodoCommand}" Height="35"/>
        </StackPanel>

        <!-- Список задач -->
        <Label Grid.Row="5" Content="СПИСОК ЗАДАЧ" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
        <ListBox Grid.Row="6" 
                 ItemsSource="{Binding TodoItems}" 
                 Background="Transparent" 
                 BorderThickness="0"
                 Margin="0,0,0,15"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Text}" 
                              IsChecked="{Binding IsDone}" 
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="5" FontSize="14"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Сообщение об ошибке -->
        <TextBlock Grid.Row="7" 
                   Text="{Binding ErrorMessage}" 
                   Foreground="Red" 
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,10"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibility}}"/>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="ОТМЕНА" Style="{StaticResource SecondaryButton}" 
                    Command="{Binding CancelCommand}" Margin="0,0,15,0" Width="100" Height="35"/>
            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}" Width="115" Height="35"/>
        </StackPanel>
    </Grid>
</UserControl>