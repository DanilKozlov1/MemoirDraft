<Window x:Class="MemoirDraft.Views.NoteView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MemoirDraft.Utils"
        Title="Заметка" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок (отображение названия) -->
        <Border x:Name="HeaderBorder" Grid.Row="0" 
                Background="{StaticResource AccentRedBrush}" 
                BorderBrush="{StaticResource GoldBrush}" 
                BorderThickness="0,0,0,2"
                MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📄" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding Title}" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontWeight="Bold" FontSize="18"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                </StackPanel>

                <Button Grid.Column="2" 
                        Content="✕" 
                        Width="30" Height="30" 
                        Background="#660000" 
                        BorderBrush="{StaticResource GoldBrush}" 
                        BorderThickness="1"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="16" 
                        Cursor="Hand"
                        Command="{Binding CloseCommand}"
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Основная область -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                <!-- Поле для редактирования названия (общее для всех типов) -->
                <TextBox Text="{Binding Title}" 
                         FontSize="16" 
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Background="#2D2D2D"
                         BorderBrush="{StaticResource GoldBrush}"
                         BorderThickness="1"
                         Padding="8"
                         Margin="0,0,0,15"/>

                <!-- Обычная заметка -->
                <StackPanel Visibility="{Binding IsTodo, Converter={StaticResource InverseBooleanToVisibility}}">
                    <Label Content="Содержание" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Content}" 
                             AcceptsReturn="True" 
                             VerticalScrollBarVisibility="Auto"
                             Padding="10" 
                             FontSize="14"
                             MinHeight="200"
                             Background="#2D2D2D"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource GoldBrush}"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- TODO-заметка -->
                <StackPanel Visibility="{Binding IsTodo, Converter={StaticResource BoolToVisibility}}">
                    <Label Content="СПИСОК ЗАДАЧ" 
           Foreground="{StaticResource GoldBrush}" 
           FontWeight="Bold" FontSize="14" 
           Margin="0,0,0,8"/>

                    <!-- Панель добавления новой задачи -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" 
                 Text="{Binding NewTodoText, UpdateSourceTrigger=PropertyChanged}" 
                 Padding="8,6" 
                 FontSize="14"
                 Background="#2D2D2D"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource GoldBrush}"
                 BorderThickness="1"
                 VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" 
                Content="➕ ДОБАВИТЬ" 
                Command="{Binding AddTodoCommand}" 
                Margin="8,0,0,0"
                Height="30"
                Padding="12,0"
                FontSize="12"
                Cursor="Hand"/>
                    </Grid>

                    <!-- Список задач -->
                    <ListBox ItemsSource="{Binding TodoItems}" 
             Background="Transparent" 
             BorderThickness="0"
             Margin="0,0,0,15"
             MinHeight="100"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3D3D3D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,4" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Кнопка "Вверх" -->
                                    <Button Grid.Column="0" 
                            Content="▲" 
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="12"
                            Cursor="Hand"
                            Command="{Binding DataContext.MoveTodoUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Width="22" Height="22"
                            Margin="0,0,2,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>
                                    <!-- Кнопка "Вниз" -->
                                    <Button Grid.Column="1" 
                            Content="▼" 
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="12"
                            Cursor="Hand"
                            Command="{Binding DataContext.MoveTodoDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Width="22" Height="22"
                            Margin="0,0,6,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>

                                    <!-- Чекбокс -->
                                    <CheckBox Grid.Column="2" 
                              IsChecked="{Binding IsDone}" 
                              Foreground="{StaticResource TextPrimaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              HorizontalAlignment="Left"/>

                                    <!-- Текст задачи -->
                                    <TextBox Grid.Column="3" 
                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0"
                             FontSize="14"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             TextWrapping="Wrap"
                             Padding="2,0"
                             MinHeight="24"
                             Margin="0,0,8,0"/>

                                    <!-- Кнопка удаления -->
                                    <Button Grid.Column="4" 
                            Content="✕" 
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="12"
                            Cursor="Hand"
                            Command="{Binding DataContext.RemoveTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Width="22" Height="22"
                            Padding="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,10,20,20">
            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}" Width="120" Height="35" Margin="0,0,15,0" Cursor="Hand"/>
            <Button Content="ЗАКРЫТЬ" Style="{StaticResource SecondaryButton}" Command="{Binding CloseCommand}" Width="120" Height="35" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>