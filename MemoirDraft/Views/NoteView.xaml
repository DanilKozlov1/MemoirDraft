<Window x:Class="MemoirDraft.Views.NoteView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MemoirDraft.Utils"
        Title="Заметка" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border x:Name="HeaderBorder" Grid.Row="0" 
                Background="{StaticResource AccentRedBrush}" 
                BorderBrush="{StaticResource GoldBrush}" 
                BorderThickness="0,0,0,2"
                MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📄" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding Title}" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontWeight="Bold" FontSize="18"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                </StackPanel>

                <Button Grid.Column="2" 
                        Content="✕" 
                        Width="30" Height="30" 
                        Background="#660000" 
                        BorderBrush="{StaticResource GoldBrush}" 
                        BorderThickness="1"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="16" 
                        Cursor="Hand"
                        Command="{Binding CloseCommand}"
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <Grid>
                <!-- Обычная заметка -->
                <StackPanel Visibility="{Binding IsTodo, Converter={StaticResource InverseBooleanToVisibility}}">
                    <Label Content="Содержание" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Content}" 
                     AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto"
                     Padding="10" 
                     FontSize="14"
                     MinHeight="200"
                     Background="#2D2D2D"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource GoldBrush}"
                     BorderThickness="1"/>
                </StackPanel>

                <!-- TODO-заметка -->
                <StackPanel Visibility="{Binding IsTodo, Converter={StaticResource BoolToVisibility}}">
                    <Label Content="Список задач" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <ListBox ItemsSource="{Binding TodoItems}" 
                     Background="Transparent" 
                     BorderThickness="0"
                     Margin="0,0,0,15"
                     MinHeight="150"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Text}" 
                                  IsChecked="{Binding IsDone}" 
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="5,3" 
                                  FontSize="14"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,10,20,20">
            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}" Width="120" Height="35" Margin="0,0,15,0" Cursor="Hand"/>
            <Button Content="ЗАКРЫТЬ" Style="{StaticResource SecondaryButton}" Command="{Binding CloseCommand}" Width="120" Height="35" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>